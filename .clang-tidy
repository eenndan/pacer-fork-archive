# pacer clang-tidy config. Advisory (not enforced by the build).
# Focus on real bug-prone patterns and obvious perf/readability wins; the
# codebase is heavy on templates/CRTP and immediate-mode GUI, so we keep the
# noisy checks off. Run: clang-tidy -p build/Release <file>
Checks: >
  bugprone-*,
  performance-*,
  modernize-use-nullptr,
  modernize-use-override,
  readability-redundant-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions
WarningsAsErrors: ''
HeaderFilterRegex: 'pacer/.*\.(hpp|h)$'
